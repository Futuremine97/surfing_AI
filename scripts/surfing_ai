#!/usr/bin/env python3
"""surfing_ai CLI — terminal private mode entry points.

  surfing_ai terminal-private [--mode M] [--root DIR]
  surfing_ai tmux-private     [--mode M] [--root DIR] [--dry-run]
  surfing_ai approvals        list | approve <id> | deny <id> [--reason R]
  surfing_ai backend-health
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))


def _queue(root: Path):
    from harness.approval_queue import ApprovalQueue
    from harness.audit_log import latest_session_dir
    session = latest_session_dir(root)
    if session is None:
        print("no terminal private sessions found under reports/")
        sys.exit(1)
    return ApprovalQueue(session / "approvals_queue.jsonl")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="surfing_ai")
    sub = parser.add_subparsers(dest="command", required=True)

    p_term = sub.add_parser("terminal-private",
                            help="private-mode REPL (local-only default)")
    p_term.add_argument("--mode", default="local-only",
                        choices=["local-only", "redacted-external", "audit"])
    p_term.add_argument("--root", default=str(ROOT))

    p_tmux = sub.add_parser("tmux-private", help="4-pane tmux workspace")
    p_tmux.add_argument("--mode", default="local-only",
                        choices=["local-only", "redacted-external", "audit"])
    p_tmux.add_argument("--root", default=str(ROOT))
    p_tmux.add_argument("--dry-run", action="store_true")

    p_appr = sub.add_parser("approvals", help="approval queue")
    p_appr.add_argument("action", choices=["list", "approve", "deny"])
    p_appr.add_argument("id", nargs="?", type=int)
    p_appr.add_argument("--reason", default="")
    p_appr.add_argument("--root", default=str(ROOT))

    sub.add_parser("backend-health",
                   help="backend health, safe vocabulary only")

    sub.add_parser("threads",
                   help="show detected logical threads and the "
                        "20/50/70/100%% worker budget")

    p_fleet = sub.add_parser(
        "fleet", help="graphical agent/subagent fleet: toggle on/off, "
                      "weight, and live thread occupancy")
    p_fleet.add_argument("--root", default=str(ROOT))
    p_fleet.add_argument("--threads", default=None,
                         help="thread budget level for the allocation "
                              "(20|50|60|70|80|90|100|max)")
    p_fleet.add_argument("--enable", metavar="TOKEN",
                         help="enable a node key, a runtime, a role, or all")
    p_fleet.add_argument("--disable", metavar="TOKEN",
                         help="disable a node key, a runtime, a role, or all")
    p_fleet.add_argument("--weight", metavar="TOKEN=N",
                         help="set the weight of a node/runtime/role")
    p_fleet.add_argument("--watch", action="store_true",
                         help="live dashboard animating dynamic thread use")
    p_fleet.add_argument("--interval", type=float, default=0.6)
    p_fleet.add_argument("--cycles", type=int, default=None,
                         help="stop after N frames (headless watch)")
    p_fleet.add_argument("--json", action="store_true",
                         help="print a JSON snapshot instead of the graphic")
    p_fleet.add_argument("--no-color", action="store_true")

    p_max = sub.add_parser("max-procs",
                           help="max-process grid: tmux panes, or "
                                "headless parallel command runner")
    p_max.add_argument("--panes", type=int, default=None,
                       help="pane/worker count (default: cores - 1)")
    p_max.add_argument("--threads", default=None,
                       help="thread budget as a utilization level: "
                            "20|50|60|70|80|90|100|max. Sets workers to "
                            "that percent of detected logical threads. "
                            "Ignored when --panes is given.")
    p_max.add_argument("--mode", default="local-only",
                       choices=["local-only", "redacted-external", "audit"])
    p_max.add_argument("--root", default=str(ROOT))
    p_max.add_argument("--dry-run", action="store_true")
    p_max.add_argument("--run", nargs="+", metavar="CMD",
                       help="headless: run these commands in parallel "
                            "across N private terminals and exit")

    p_bg = sub.add_parser(
        "bg", help="background jobs that persist across shell/CLI calls")
    p_bg.add_argument("action",
                      choices=["start", "list", "status", "stop", "logs",
                               "prune"])
    p_bg.add_argument("rest", nargs="*",
                      help="command words (start) or a job id (others)")
    p_bg.add_argument("--root", default=str(ROOT))
    p_bg.add_argument("--tail", type=int, default=40)

    p_cowork = sub.add_parser(
        "cowork", help="long-running, proactive agentic mode: give a "
                       "mission and it works, verifies, and monitors")
    p_cowork.add_argument("action",
                          choices=["start", "run", "status", "journal",
                                   "list", "stop"])
    p_cowork.add_argument("rest", nargs="*",
                          help="mission words (start) or a session id")
    p_cowork.add_argument("-s", "--session", default=None)
    p_cowork.add_argument("-c", "--cycles", type=int, default=6)
    p_cowork.add_argument("--watch", action="store_true",
                          help="keep advancing/monitoring on an interval")
    p_cowork.add_argument("--interval", type=float, default=1.0)
    p_cowork.add_argument("--tail", type=int, default=20)
    p_cowork.add_argument("--root", default=str(ROOT))

    p_desk = sub.add_parser("desktop",
                            help="desktop bridge: localhost UI + JSON API")
    p_desk.add_argument("--root", default=str(ROOT))
    p_desk.add_argument("--host", default="127.0.0.1")
    p_desk.add_argument("--port", type=int, default=4175)
    p_desk.add_argument("--token", default=None,
                        help="shared token (default: random, printed once)")
    p_desk.add_argument("--open", action="store_true",
                        help="open the UI in the default browser")

    args = parser.parse_args(argv)

    if args.command == "terminal-private":
        from harness.terminal_private_mode import run_repl
        run_repl(root=args.root, mode=args.mode)
        return 0

    if args.command == "tmux-private":
        from harness.tmux_adapter import launch
        result = launch(root=args.root, mode=args.mode,
                        dry_run=args.dry_run)
        for key, value in result.items():
            print(f"{key}: {value}")
        if result["status"] == "TMUX_NOT_FOUND":
            print("run instead:", result["fallback"])
            return 0
        return 0 if result["status"] in ("LAUNCHED", "DRY_RUN") else 1

    if args.command == "approvals":
        queue = _queue(Path(args.root))
        if args.action == "list":
            records = queue.list()
            if not records:
                print("queue is empty")
            for r in records:
                print(f"#{r['id']} [{r['status']}] ({r['kind']}) "
                      f"{r['label']}")
            return 0
        if args.id is None:
            print("an id is required for approve/deny")
            return 1
        if args.action == "approve":
            print(queue.approve(args.id))
        else:
            print(queue.deny(args.id, args.reason))
        return 0

    if args.command == "backend-health":
        from harness.backend_health import format_health, summarize_health
        print(format_health(summarize_health(project_root=str(ROOT))))
        return 0

    if args.command == "cowork":
        from harness import autopilot
        action = args.action

        def _resolve_sid():
            sid = args.session or (args.rest[0] if args.rest else None) \
                or autopilot.latest(args.root)
            return sid

        if action == "start":
            mission = " ".join(args.rest).strip()
            if not mission:
                print("usage: surfing_ai cowork start \"<mission>\"")
                return 1
            session = autopilot.start(mission, args.root)
            print(f"cowork session {session.sid} started")
            print(f"  mission: {mission}")
            print("  run it:  surfing_ai cowork run -s "
                  f"{session.sid} --watch")
            return 0

        if action == "list":
            rows = autopilot.list_sessions(args.root)
            if not rows:
                print("no cowork sessions")
                return 0
            for r in rows:
                m = r["mission"][:44]
                print(f"  {r['session']}  {r['status']:<10} "
                      f"step {r['step']:<3}  {m}")
            return 0

        sid = _resolve_sid()
        if not sid:
            print("no cowork session found; start one first")
            return 1
        try:
            session = autopilot.load(args.root, sid)
        except FileNotFoundError:
            print(f"no such cowork session: {sid}")
            return 1

        if action == "status":
            import json as _json
            print(_json.dumps(autopilot.status_summary(session), indent=2))
            return 0
        if action == "journal":
            for e in session.read_journal()[-args.tail:]:
                ph = f"[{e['phase']}] " if e.get("phase") else ""
                print(f"  #{e['step']:<3} {ph}{e['type']}: {e['message']}")
            return 0
        if action == "stop":
            autopilot.stop(session)
            print(f"cowork session {sid} stopped")
            return 0
        if action == "run":
            if args.watch:
                import time as _t
                try:
                    while session.state["status"] != "stopped":
                        entry = autopilot.tick(session)
                        ph = f"[{entry['phase']}] " if entry.get("phase") \
                            else ""
                        print(f"#{entry['step']:<3} {ph}{entry['type']}: "
                              f"{entry['message']}", flush=True)
                        if args.cycles and entry["step"] >= args.cycles:
                            break
                        _t.sleep(max(0.0, args.interval))
                except KeyboardInterrupt:
                    pass
                return 0
            for entry in autopilot.run(session, cycles=args.cycles):
                ph = f"[{entry['phase']}] " if entry.get("phase") else ""
                print(f"#{entry['step']:<3} {ph}{entry['type']}: "
                      f"{entry['message']}")
            return 0

    if args.command == "bg":
        from harness import bg_jobs
        action = args.action
        if action == "start":
            command = " ".join(args.rest).strip()
            if not command:
                print("usage: surfing_ai bg start \"<command>\"")
                return 1
            job = bg_jobs.start(command, args.root)
            if job.status == "blocked":
                print(f"BLOCKED: {', '.join(job.reasons)}")
                if job.alternative:
                    print(f"  alternative: {job.alternative}")
                return 1
            print(f"started {job.id}  pid {job.pid}\n  log: {job.log}")
            return 0
        if action == "list":
            print(bg_jobs.format_table(args.root))
            return 0
        if action in ("status", "stop", "logs"):
            if not args.rest:
                print(f"usage: surfing_ai bg {action} <id>")
                return 1
            job_id = args.rest[0]
            try:
                if action == "status":
                    rec = bg_jobs.get(args.root, job_id)
                    if rec is None:
                        print(f"no such job: {job_id}")
                        return 1
                    import json as _json
                    print(_json.dumps(rec, indent=2))
                elif action == "stop":
                    rec = bg_jobs.stop(args.root, job_id)
                    print(f"stopped {job_id} ({rec['status']})")
                else:  # logs
                    print(bg_jobs.logs(args.root, job_id, tail=args.tail))
            except KeyError as exc:
                print(str(exc))
                return 1
            return 0
        if action == "prune":
            removed = bg_jobs.prune(args.root)
            print(f"pruned {removed} finished job(s)")
            return 0

    if args.command == "threads":
        from harness.thread_budget import format_table
        print(format_table())
        return 0

    if args.command == "fleet":
        from harness.agent_fleet import (Fleet, render, render_watch,
                                         snapshot)
        fleet = Fleet.load(args.root)
        changed = False
        if args.enable:
            nodes = fleet.set_enabled(args.enable, True)
            print("enabled: " + ", ".join(n.key for n in nodes))
            changed = True
        if args.disable:
            nodes = fleet.set_enabled(args.disable, False)
            print("disabled: " + ", ".join(n.key for n in nodes))
            changed = True
        if args.weight:
            token, _, val = args.weight.partition("=")
            nodes = fleet.set_weight(token, int(val))
            print(f"weight {int(val)}: " + ", ".join(n.key for n in nodes))
            changed = True
        if changed:
            fleet.save(args.root)
        if args.json:
            import json as _json
            print(_json.dumps(snapshot(fleet, args.root, args.threads),
                              indent=2))
            return 0
        if args.watch:
            render_watch(fleet, args.root, args.threads,
                         interval=args.interval, cycles=args.cycles,
                         color=not args.no_color)
            return 0
        print(render(fleet, args.root, args.threads,
                     color=not args.no_color))
        return 0

    if args.command == "desktop":
        from harness.desktop_bridge import serve
        serve(root=args.root, host=args.host, port=args.port,
              token=args.token, open_browser=args.open)
        return 0

    if args.command == "max-procs":
        from harness.process_orchestrator import ParallelRunner, max_processes
        if args.panes:
            count = args.panes
        elif args.threads:
            from harness.thread_budget import logical_threads, resolve_workers
            count = resolve_workers(args.threads)
            print(f"thread budget: {args.threads} of {logical_threads()} "
                  f"logical threads -> {count} worker(s)")
        else:
            from harness.thread_budget import resolve_workers, saved_level
            lvl = saved_level(args.root)
            if lvl:
                count = resolve_workers(lvl)
                print(f"thread budget (saved {lvl}%) -> {count} worker(s)")
            else:
                count = max_processes()
        if args.run:
            runner = ParallelRunner(root=args.root, mode=args.mode,
                                    workers=count)
            print(f"running {len(args.run)} command(s) across "
                  f"{runner.workers} private terminal worker(s)")
            for result in runner.run(args.run):
                flag = "BLOCKED" if result["blocked"] else "ok"
                print(f"[w{result['worker']}] ({flag}) "
                      f"$ {result['command']}")
                if result["output"]:
                    print("    " + result["output"]
                          .replace("\n", "\n    "))
            totals = runner.aggregate_counters()
            runner.close()
            print(f"totals: {totals}")
            return 1 if totals["files_sent_external"] else 0
        from harness.tmux_adapter import launch_grid
        result = launch_grid(root=args.root, panes=count, mode=args.mode,
                             dry_run=args.dry_run)
        for key, value in result.items():
            if key == "manual_commands":
                print("manual_commands:")
                for command in value:
                    print(f"  {command}")
            else:
                print(f"{key}: {value}")
        return 0 if result["status"] in ("LAUNCHED", "DRY_RUN",
                                         "TMUX_NOT_FOUND") else 1

    return 1


if __name__ == "__main__":
    sys.exit(main())
