<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.surfingai.nightly-train</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-i</string>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>__PROJECT_ROOT__/training/nightly_train.py</string>
    <string>--deadline</string>
    <string>06:30</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>WorkingDirectory</key>
  <string>__PROJECT_ROOT__</string>
  <key>StandardOutPath</key>
  <string>__PROJECT_ROOT__/training/logs/nightly.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_ROOT__/training/logs/nightly.err.log</string>
  <key>Nice</key>
  <integer>10</integer>
</dict>
</plist>
