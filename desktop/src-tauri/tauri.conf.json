{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Surfing AI Desktop",
  "version": "0.1.0",
  "identifier": "ai.surfing.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../harness/*.py": "harness/",
      "../../scripts/surfing_ai": "scripts/",
      "../../config/example_private_mode.yaml": "config/",
      "../ui/index.html": "desktop/ui/"
    }
  }
}
